APP_NAME="NIVICO Electronic Mart"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nivico
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@nivico.id"
MAIL_FROM_NAME="${APP_NAME}"

# Toko
SHOP_FREE_SHIPPING_MIN=150000
SHOP_DEFAULT_ONGKIR=15000

# ── RajaOngkir / Komerce ──
RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
RAJAONGKIR_API_KEY=
RAJAONGKIR_ORIGIN=
RAJAONGKIR_ORIGIN_TYPE=city
RAJAONGKIR_COURIERS=jne:sicepat:jnt
RAJAONGKIR_DEFAULT_WEIGHT=1000

# ── Midtrans ──
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
